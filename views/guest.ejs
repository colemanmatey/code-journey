<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
</head>
<body>
    <%- include('./partials/header.ejs') %>
    <%- include('./partials/nav.ejs') %>
    
    <main class="content">
        <% if (data.length > 0) { %>
            <% data.forEach(i => { %>
                <h2>ID: <%= i.id%></h2>
                <p>Name: <%= i.name %></p>
                <p>Age: <%= i.age %></p>
                <p>Email: <%= i.email %></p>
                <p>Occupation: <%= i.occupation %></p>
                <p>City: <%= i.city %></p>
                <p>Country: <%= i.country %></p>
            <% }); %>
        <% } else { %>
            <p>No guests available</p>
        <% } %>
    </main>

    <%- include('./partials/footer.ejs') %>
</body>
</html>